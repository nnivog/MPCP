From 89e70d4685fd34ab400be1295aa56c9da1cc50e6 Mon Sep 17 00:00:00 2001
From: Govinda Upadhyay <govinda.upadhyay@sipradi.com>
Date: Sun, 12 Apr 2026 05:31:53 +0000
Subject: [PATCH 3/3] fix: set row_factory before emp_sectors backfill in
 init_db

Plain sqlite3.connect() returns tuple rows by default. The backfill
loop used r['dept'] and r['id'] (string keys) which raised:
  TypeError: tuple indices must be integers or slices, not str
Fix: set con.row_factory = sqlite3.Row before executing the SELECT
so column-name access works correctly.
---
 app.py | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/app.py b/app.py
index bebc8df..0de46a2 100644
--- a/app.py
+++ b/app.py
@@ -179,6 +179,8 @@ def init_db():
             PRIMARY KEY(emp_id, loc_id));
     """)
     # Back-fill emp_sectors from existing employees.dept (one-time migration)
+    # Must set row_factory on con so column names work (init_db uses plain sqlite3.connect)
+    con.row_factory = sqlite3.Row
     rows = con.execute("SELECT id, dept FROM employees WHERE dept != ''").fetchall()
     for r in rows:
         sec = con.execute("SELECT id FROM sectors WHERE code=?", (r['dept'],)).fetchone()
